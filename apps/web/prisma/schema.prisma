generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrganizationMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum AuditActorType {
  SYSTEM
  USER
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  emailVerified        Boolean              @default(false)
  name                 String?
  image                String?
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  accounts             Account[]
  sessions             Session[]
  organizationMembers  OrganizationMember[]
  auditLogs            AuditLog[]           @relation("AuditLogActorUser")

  @@index([createdAt])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@index([expiresAt])
}

model Organization {
  id          String               @id @default(cuid())
  slug        String               @unique
  name        String
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     OrganizationMember[]
  auditLogs   AuditLog[]
  students    Student[]
  swimGroups  SwimGroup[]
  skills      Skill[]
  courses     Course[]

  @@index([createdAt])
}

model Student {
  id               String            @id @default(cuid())
  organizationId   String
  firstName        String
  lastName         String
  dateOfBirth      DateTime?
  identityKey      String
  swimLevel        String
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  groupMemberships GroupMembership[]
  courseEnrollments CourseEnrollment[]
  studentSkills    StudentSkill[]

  @@unique([organizationId, identityKey])
  @@index([organizationId, isActive])
  @@index([organizationId, swimLevel])
  @@index([organizationId, lastName, firstName])
}

model SwimGroup {
  id             String            @id @default(cuid())
  organizationId String
  name           String
  swimLevel      String
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships    GroupMembership[]

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
}

model GroupMembership {
  id        String    @id @default(cuid())
  groupId   String
  studentId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  group     SwimGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@index([groupId])
  @@index([studentId])
}

model OrganizationMember {
  id             String                 @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationMemberRole @default(MEMBER)
  isActive       Boolean                @default(true)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model AuditLog {
  id             String         @id @default(cuid())
  organizationId String?
  actorUserId    String?
  actorType      AuditActorType @default(SYSTEM)
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime       @default(now())
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  actorUser      User?          @relation("AuditLogActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
}

model Skill {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  description    String?
  swimLevel      String
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  courseSkills   CourseSkill[]
  studentSkills  StudentSkill[]

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
  @@index([organizationId, swimLevel])
}

model StudentSkill {
  id         String    @id @default(cuid())
  studentId  String
  skillId    String
  achievedAt DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  skill      Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([studentId, skillId])
  @@index([studentId])
  @@index([skillId])
}

model Course {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  description    String?
  swimLevel      String
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  courseSkills   CourseSkill[]
  enrollments    CourseEnrollment[]

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
  @@index([organizationId, swimLevel])
}

model CourseSkill {
  id        String   @id @default(cuid())
  courseId  String
  skillId   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([courseId, skillId])
  @@index([courseId])
  @@index([skillId])
}

model CourseEnrollment {
  id        String   @id @default(cuid())
  courseId  String
  studentId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([courseId])
  @@index([studentId])
}
