NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_NAME=SplashTrack
APP_BASE_URL=http://localhost:3000
# Comma-separated additional browser origins allowed to call Better Auth.
# Example for LAN + reverse-proxy mobile testing:
# AUTH_TRUSTED_ORIGINS=https://splashtrack.jack.ldam.nl,http://10.2.1.13:3000
AUTH_TRUSTED_ORIGINS=
LOG_LEVEL=info
POSTGRES_DB=splashtrack
POSTGRES_USER=splashtrack
POSTGRES_PASSWORD=splashtrack
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://splashtrack:splashtrack@postgres:5432/splashtrack
DIRECT_URL=postgresql://splashtrack:splashtrack@postgres:5432/splashtrack
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
